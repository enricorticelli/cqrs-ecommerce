---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.svelte';
import ToastContainer from '../components/ToastContainer.svelte';

const { title = 'CQRS Commerce' } = Astro.props;
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f4ecde" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,600&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title} — CQRS Commerce</title>
  </head>
  <body>
    <SiteHeader client:load />
    <main class="mx-auto max-w-7xl space-y-8 p-4 pb-16 md:p-8">
      <slot />
    </main>
    <footer class="border-t border-slate-200 bg-white/60 py-8 text-center text-xs text-slate-400">
      <p>CQRS Commerce · Demo storefront con microservizi .NET 8 + Astro + Svelte</p>
      <p class="mt-1">Catalog · Cart · Order · Payment · Warehouse · Shipping · Gateway</p>
    </footer>
    <ToastContainer client:load />
  </body>
</html>
