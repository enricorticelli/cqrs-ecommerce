---
import MainLayout from '../layouts/MainLayout.astro';

const publicGatewayUrl = import.meta.env.PUBLIC_GATEWAY_URL ?? '';
---

<MainLayout title="Login | Commerce">
  <div class="mx-auto w-full max-w-[520px] py-10 md:py-12">
    <section class="surface-card pop-in p-7 md:p-9">
      <h1 class="font-title text-3xl font-extrabold text-[#202223]">Accedi</h1>
      <p class="mt-2 text-sm text-[#616161]">Accedi al tuo account cliente e continua dove avevi lasciato.</p>

      <form id="login-form" class="mt-7 space-y-6" method="post">
        <label class="block">
          <span class="form-label">Email</span>
          <input id="email" class="form-input" type="email" autocomplete="email" required />
        </label>

        <label class="block">
          <span class="form-label">Password</span>
          <div class="relative">
            <input id="password" class="form-input pr-12" type="password" autocomplete="current-password" required />
            <button id="toggle-password" class="form-toggle" type="button" aria-label="Mostra password">Mostra</button>
          </div>
        </label>

        <div class="space-y-3 pt-1">
          <button class="btn-primary w-full" type="submit">Accedi</button>
          <p class="text-center text-sm text-[#616161]">Non hai un account? <a class="font-semibold text-[#008060]" href="/register">Registrati</a></p>
        </div>
      </form>

      <p id="error" class="mt-4 hidden rounded-lg bg-rose-50 px-3 py-2.5 text-sm text-rose-700"></p>
    </section>
  </div>

  <script define:vars={{ publicGatewayUrl }}>
    const ACCESS_TOKEN_KEY = 'store:accessToken';
    const REFRESH_TOKEN_KEY = 'store:refreshToken';

    const configuredGatewayUrl = publicGatewayUrl;
    const gatewayUrl = configuredGatewayUrl ||
      (['localhost', '127.0.0.1'].includes(window.location.hostname)
        ? 'http://localhost:18080'
        : 'http://localhost:8080');

    function saveAuthTokens(tokens) {
      localStorage.setItem(ACCESS_TOKEN_KEY, tokens.accessToken);
      localStorage.setItem(REFRESH_TOKEN_KEY, tokens.refreshToken);
    }

    function initLoginForm() {
      const form = /** @type {HTMLFormElement | null} */ (document.querySelector('#login-form'));
      if (!form || form.dataset.bound === 'true') {
        return;
      }

      form.dataset.bound = 'true';

      const error = /** @type {HTMLElement | null} */ (document.querySelector('#error'));
      const emailInput = /** @type {HTMLInputElement | null} */ (form.querySelector('#email'));
      const passwordInput = /** @type {HTMLInputElement | null} */ (form.querySelector('#password'));
      const togglePasswordButton = /** @type {HTMLButtonElement | null} */ (form.querySelector('#toggle-password'));

      if (!form || !emailInput || !passwordInput) {
        delete form.dataset.bound;
        return;
      }

      togglePasswordButton?.addEventListener('click', () => {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        togglePasswordButton.textContent = isPassword ? 'Nascondi' : 'Mostra';
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        error?.classList.add('hidden');

        const email = emailInput.value ?? '';
        const password = passwordInput.value ?? '';

        try {
          const response = await fetch(`${gatewayUrl}/api/store/account/v1/users/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: email, password }),
          });

          if (!response.ok) {
            const err = await response.json().catch(() => null);
            throw new Error(err?.detail ?? 'Credenziali non valide');
          }

          const auth = await response.json();
          saveAuthTokens({ accessToken: auth.accessToken, refreshToken: auth.refreshToken });
          window.location.href = '/account';
        } catch (err) {
          if (error) {
            error.textContent = err instanceof Error ? err.message : 'Login non riuscito';
            error.classList.remove('hidden');
          }
        }
      });
    }

    initLoginForm();
    document.addEventListener('DOMContentLoaded', initLoginForm);
    document.addEventListener('astro:page-load', initLoginForm);
    window.addEventListener('pageshow', initLoginForm);
  </script>
</MainLayout>
