---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Login | Commerce">
  <div class="mx-auto w-full max-w-[520px] py-10">
    <section class="surface-card p-6 md:p-7">
      <h1 class="font-title text-3xl font-extrabold text-[#202223]">Accedi</h1>
      <p class="mt-2 text-sm text-[#616161]">Accedi al tuo account cliente.</p>

      <form id="login-form" class="mt-6 space-y-3">
        <label>
          <span class="form-label">Email</span>
          <input id="email" class="form-input" type="email" required />
        </label>

        <label>
          <span class="form-label">Password</span>
          <input id="password" class="form-input" type="password" required />
        </label>

        <button class="btn-primary w-full" type="submit">Accedi</button>
        <p class="text-center text-sm text-[#616161]">Non hai un account? <a class="font-semibold text-[#008060]" href="/register">Registrati</a></p>
      </form>

      <p id="error" class="mt-3 hidden rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700"></p>
    </section>
  </div>

  <script type="module">
    import { loginCustomer } from '../lib/api';
    import { saveAuthTokens } from '../lib/auth';

    const form = document.querySelector('#login-form');
    const error = document.querySelector('#error');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      error?.classList.add('hidden');

      const email = /** @type {HTMLInputElement} */ (document.querySelector('#email'))?.value ?? '';
      const password = /** @type {HTMLInputElement} */ (document.querySelector('#password'))?.value ?? '';

      try {
        const auth = await loginCustomer({ username: email, password });
        saveAuthTokens({ accessToken: auth.accessToken, refreshToken: auth.refreshToken });
        window.location.href = '/account';
      } catch (err) {
        if (error) {
          error.textContent = err instanceof Error ? err.message : 'Login non riuscito';
          error.classList.remove('hidden');
        }
      }
    });
  </script>
</MainLayout>
