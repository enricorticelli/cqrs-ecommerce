---
import MainLayout from '../layouts/MainLayout.astro';

const publicGatewayUrl = import.meta.env.PUBLIC_GATEWAY_URL ?? '';
---

<MainLayout title="Registrazione | Commerce">
  <div class="mx-auto w-full max-w-[620px] py-10 md:py-12">
    <section class="surface-card pop-in p-7 md:p-9">
      <h1 class="font-title text-3xl font-extrabold text-[#202223]">Crea account</h1>
      <p class="mt-2 text-sm text-[#616161]">Registrati per salvare indirizzi, monitorare ordini e velocizzare il checkout.</p>

      <form id="register-form" class="mt-7 space-y-6" method="post">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="form-label">Nome</span>
            <input id="firstName" class="form-input" required />
          </label>
          <label class="block">
            <span class="form-label">Cognome</span>
            <input id="lastName" class="form-input" required />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block sm:col-span-2">
            <span class="form-label">Email</span>
            <input id="email" class="form-input" type="email" autocomplete="email" required />
          </label>

          <label class="block sm:col-span-2">
            <span class="form-label">Telefono <span class="text-[#8c9196] normal-case tracking-normal">(opzionale)</span></span>
            <input id="phone" class="form-input" autocomplete="tel" />
          </label>
        </div>

        <div class="surface-muted reveal p-5">
          <label class="block">
            <span class="form-label">Password</span>
            <div class="relative">
              <input id="password" class="form-input pr-12" type="password" minlength="8" autocomplete="new-password" required />
              <button id="toggle-password" class="form-toggle" type="button" aria-label="Mostra password">Mostra</button>
            </div>
          </label>

        
          <label class="mt-5 block">
            <span class="form-label">Conferma password</span>
            <div class="relative">
              <input id="confirmPassword" class="form-input pr-12" type="password" minlength="8" autocomplete="new-password" required />
              <button id="toggle-confirm-password" class="form-toggle" type="button" aria-label="Mostra conferma password">Mostra</button>
            </div>
          </label>

          <div class="mt-4">
            <div class="mb-2 flex items-center justify-between text-xs">
              <span class="font-semibold uppercase tracking-wide text-[#6d7175]">Sicurezza password</span>
              <span id="password-strength-text" class="font-semibold text-[#6d7175]">Da valutare</span>
            </div>
            <div class="password-strength-meter" role="progressbar" aria-label="Sicurezza password" aria-valuemin="0" aria-valuemax="4" aria-valuenow="0">
              <span class="strength-segment"></span>
              <span class="strength-segment"></span>
              <span class="strength-segment"></span>
              <span class="strength-segment"></span>
            </div>
            <ul id="password-checklist" class="mt-4 grid gap-1.5 text-xs text-[#616161]">
              <li data-rule="length">Almeno 8 caratteri</li>
              <li data-rule="mixed">Maiuscole e minuscole</li>
              <li data-rule="number">Almeno un numero</li>
              <li data-rule="symbol">Almeno un simbolo (es. !@#$)</li>
            </ul>
          </div>

          <p id="password-mismatch" class="mt-3 hidden rounded-lg bg-amber-50 px-3 py-2.5 text-xs font-medium text-amber-800">
            Le password non coincidono.
          </p>
        </div>

        <div class="space-y-3 pt-1">
          <button class="btn-primary w-full" type="submit">Registrati</button>
          <p class="text-center text-sm text-[#616161]">Hai gia un account? <a class="font-semibold text-[#008060]" href="/login">Accedi</a></p>
        </div>
      </form>

      <p id="error" class="mt-4 hidden rounded-lg bg-rose-50 px-3 py-2.5 text-sm text-rose-700"></p>
    </section>
  </div>

  <script define:vars={{ publicGatewayUrl }}>
    const ACCESS_TOKEN_KEY = 'store:accessToken';
    const REFRESH_TOKEN_KEY = 'store:refreshToken';

    const configuredGatewayUrl = publicGatewayUrl;
    const gatewayUrl = configuredGatewayUrl ||
      (['localhost', '127.0.0.1'].includes(window.location.hostname)
        ? 'http://localhost:18080'
        : 'http://localhost:8080');

    function saveAuthTokens(tokens) {
      localStorage.setItem(ACCESS_TOKEN_KEY, tokens.accessToken);
      localStorage.setItem(REFRESH_TOKEN_KEY, tokens.refreshToken);
    }

    function evaluatePassword(password) {
      const hasLength = password.length >= 8;
      const hasMixed = /[a-z]/.test(password) && /[A-Z]/.test(password);
      const hasNumber = /\d/.test(password);
      const hasSymbol = /[^a-zA-Z\d]/.test(password);
      const hasLongLength = password.length >= 12;
      const hasNoRepeatedPattern = !/(.)\1\1/.test(password);

      let score = 0;
      if (hasLength) score += 1;
      if (hasMixed) score += 1;
      if (hasNumber) score += 1;
      if (hasSymbol) score += 1;
      if (hasLongLength && hasNoRepeatedPattern && score > 0) score += 1;

      const normalizedScore = Math.max(0, Math.min(4, score));

      let label = 'Molto debole';
      if (normalizedScore === 2) label = 'Debole';
      if (normalizedScore === 3) label = 'Buona';
      if (normalizedScore === 4) label = 'Ottima';

      return {
        score: normalizedScore,
        label,
        rules: { hasLength, hasMixed, hasNumber, hasSymbol }
      };
    }

    /** @param {HTMLInputElement | null} input */
    function wireToggleButton(input, buttonId) {
      const button = /** @type {HTMLButtonElement | null} */ (document.querySelector(`#${buttonId}`));
      button?.addEventListener('click', () => {
        if (!input) return;
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        button.textContent = isPassword ? 'Nascondi' : 'Mostra';
      });
    }

    function initRegisterForm() {
      const form = /** @type {HTMLFormElement | null} */ (document.querySelector('#register-form'));
      if (!form || form.dataset.bound === 'true') {
        return;
      }

      form.dataset.bound = 'true';

      const error = /** @type {HTMLElement | null} */ (document.querySelector('#error'));
      const passwordInput = /** @type {HTMLInputElement | null} */ (form.querySelector('#password'));
      const confirmPasswordInput = /** @type {HTMLInputElement | null} */ (form.querySelector('#confirmPassword'));
      const passwordStrengthText = /** @type {HTMLElement | null} */ (form.querySelector('#password-strength-text'));
      const strengthMeter = /** @type {HTMLElement | null} */ (form.querySelector('.password-strength-meter'));
      const strengthSegments = Array.from(form.querySelectorAll('.strength-segment'));
      const passwordMismatch = /** @type {HTMLElement | null} */ (form.querySelector('#password-mismatch'));
      const checklist = {
        length: form.querySelector('[data-rule="length"]'),
        mixed: form.querySelector('[data-rule="mixed"]'),
        number: form.querySelector('[data-rule="number"]'),
        symbol: form.querySelector('[data-rule="symbol"]')
      };

      if (!passwordInput || !confirmPasswordInput) {
        delete form.dataset.bound;
        return;
      }

      const updateChecklistState = (ruleElement, isValid) => {
        if (!ruleElement) return;
        ruleElement.classList.toggle('password-rule-ok', isValid);
      };

      const updatePasswordStrengthUi = () => {
        const password = passwordInput.value;
        const { score, label, rules } = evaluatePassword(password);

        strengthSegments.forEach((segment, index) => {
          segment.classList.toggle('is-active', index < score);
        });

        strengthMeter?.setAttribute('aria-valuenow', String(score));
        strengthMeter?.setAttribute('data-strength', String(score));

        if (passwordStrengthText) {
          passwordStrengthText.textContent = password.length > 0 ? label : 'Da valutare';
        }

        updateChecklistState(checklist.length, rules.hasLength);
        updateChecklistState(checklist.mixed, rules.hasMixed);
        updateChecklistState(checklist.number, rules.hasNumber);
        updateChecklistState(checklist.symbol, rules.hasSymbol);
      };

      const updatePasswordMatchUi = () => {
        const hasMismatch = confirmPasswordInput.value.length > 0 && passwordInput.value !== confirmPasswordInput.value;
        passwordMismatch?.classList.toggle('hidden', !hasMismatch);
        return !hasMismatch;
      };

      const syncPasswordUi = () => {
        updatePasswordStrengthUi();
        updatePasswordMatchUi();
      };

      wireToggleButton(passwordInput, 'toggle-password');
      wireToggleButton(confirmPasswordInput, 'toggle-confirm-password');

      passwordInput.addEventListener('input', syncPasswordUi);
      confirmPasswordInput.addEventListener('input', updatePasswordMatchUi);
      updatePasswordStrengthUi();

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        error?.classList.add('hidden');

        const firstName = /** @type {HTMLInputElement | null} */ (form.querySelector('#firstName'))?.value ?? '';
        const lastName = /** @type {HTMLInputElement | null} */ (form.querySelector('#lastName'))?.value ?? '';
        const email = /** @type {HTMLInputElement | null} */ (form.querySelector('#email'))?.value ?? '';
        const phone = /** @type {HTMLInputElement | null} */ (form.querySelector('#phone'))?.value ?? '';
        const password = passwordInput.value;
        const confirmPassword = confirmPasswordInput.value;

        if (password !== confirmPassword) {
          passwordMismatch?.classList.remove('hidden');
          return;
        }

        try {
          const response = await fetch(`${gatewayUrl}/api/store/account/v1/users/register`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              firstName,
              lastName,
              email,
              phone: phone.trim(),
              password,
            }),
          });

          if (!response.ok) {
            const err = await response.json().catch(() => null);
            throw new Error(err?.detail ?? 'Registrazione non riuscita');
          }

          const auth = await response.json();
          saveAuthTokens({ accessToken: auth.accessToken, refreshToken: auth.refreshToken });
          window.location.href = '/account';
        } catch (err) {
          if (error) {
            error.textContent = err instanceof Error ? err.message : 'Registrazione non riuscita';
            error.classList.remove('hidden');
          }
        }
      });
    }

    initRegisterForm();
    document.addEventListener('DOMContentLoaded', initRegisterForm);
    document.addEventListener('astro:page-load', initRegisterForm);
    window.addEventListener('pageshow', initRegisterForm);
  </script>
</MainLayout>
