---
import '../styles/global.css';
import { isAuthenticated, setAuthCookie, validateCredentials } from '../lib/auth';

const nextPath = Astro.url.searchParams.get('next') || '/';

if (Astro.request.method === 'GET' && isAuthenticated(Astro.cookies)) {
  return Astro.redirect(nextPath);
}

let error = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const username = String(data.get('username') ?? '').trim();
  const password = String(data.get('password') ?? '');

  const login = await validateCredentials(username, password);
  if (login) {
    setAuthCookie(Astro.cookies, login);
    return Astro.redirect(nextPath);
  }

  error = 'Credenziali non valide';
}
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | Backoffice</title>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto flex min-h-screen w-full max-w-[520px] items-center px-4 py-10">
      <section class="surface-card w-full p-6 md:p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#4a5870]">Commerce</p>
        <h1 class="mt-2 text-3xl font-extrabold text-[#1c2430]">Accesso Backoffice</h1>
        <p class="mt-2 text-sm text-[#5a6472]">Inserisci username e password per accedere all'area amministrativa.</p>

        {error && (
          <p class="mt-4 rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700">{error}</p>
        )}

        <form class="mt-5 space-y-3" method="post">
          <div>
            <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.12em] text-[#5a6472]" for="username">
              Username
            </label>
            <input id="username" name="username" class="form-input" autocomplete="username" required />
          </div>

          <div>
            <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.12em] text-[#5a6472]" for="password">
              Password
            </label>
            <input id="password" name="password" type="password" class="form-input" autocomplete="current-password" required />
          </div>

          <button class="btn-primary w-full" type="submit">Accedi</button>
        </form>
      </section>
    </main>
  </body>
</html>
